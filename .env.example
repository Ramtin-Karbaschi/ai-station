# AI Station environment template
# Copy to .env and fill required values. Never commit the real .env.

COMPOSE_FILE=compose.yml:compose.models.yml:compose.hardening.yaml:compose.local-builds.yaml:compose.images.lock.yaml
COMPOSE_PROJECT_NAME=ai-station
AI_STATION_NAME=ai-station

# Host paths
MODELS_DIR=/srv/ai-station/models
AI_STATION_PROVIDERS=/opt/ai-station/config/providers.yaml

# Ports (all published on 127.0.0.1 by Compose)
WEBUI_PORT=3000
LITELLM_PORT=4000
GATEWAY_PORT=8888
UI_GATEWAY_PORT=8890
SEARXNG_PORT=8889
GENERAL_LLM_PORT=8082
CODER_LLM_PORT=8083
REASONING_LLM_PORT=8084
VISION_LLM_PORT=8085
EMBEDDER_PORT=8090
RERANKER_PORT=8091
TIKA_PORT=9998

# llama.cpp model files (also mirrored in .env.models)
LLM_GENERAL_MODEL_FILE=general/qwen3.6-35b-a3b-ud-q4_k_m.gguf
LLM_GENERAL_CONTEXT=8192
EMBEDDING_MODEL_FILE=embedding/qwen3-embedding-0.6b-q8_0.gguf
EMBEDDING_CONTEXT=8192

# Secrets — generate locally
POSTGRES_USER=ai
POSTGRES_PASSWORD=
POSTGRES_DB=ai_station
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
LITELLM_DATABASE_URL=
OPENWEBUI_DATABASE_URL=
PGVECTOR_DB_URL=
WEBUI_SECRET_KEY=
UI_USERNAME=admin
UI_PASSWORD=
