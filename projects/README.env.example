# Example project credentials template.
# Real credentials are created by: ai projects create <id>
#
# Host process:
#   LLM_BASE_URL=http://127.0.0.1:4000/v1
#
# Docker Compose service on network ai-platform:
#   LLM_BASE_URL=http://llm-gateway:4000/v1
#
# networks:
#   ai-platform:
#     external: true

LLM_BASE_URL=http://127.0.0.1:4000/v1
LLM_BASE_URL_DOCKER=http://llm-gateway:4000/v1
LLM_API_KEY=sk-local-REPLACE_ME
LLM_MODEL=local-general
LLM_TIMEOUT_SECONDS=120
LLM_DOCKER_NETWORK=ai-platform
